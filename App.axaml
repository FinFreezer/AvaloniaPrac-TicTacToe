<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MyApp.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="Styles/AppDefaultStyles.axaml"></StyleInclude>
    </Application.Styles>

            <Application.Resources>
                <SolidColorBrush x:Key="PrimaryText">Black</SolidColorBrush>
                <SolidColorBrush x:Key="PrimaryBackground">#FFFFFF</SolidColorBrush>
                <LinearGradientBrush x:Key="PrimaryBackgroundGradient" StartPoint="0%, 0%" EndPoint="100%, 100%">
                    <GradientStop Offset="0" Color="White"></GradientStop>
                    <GradientStop Offset="1" Color="#3C3D40"></GradientStop>
                </LinearGradientBrush>
            </Application.Resources>
</Application>