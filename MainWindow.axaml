<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        Width="1600" Height="900"
        x:Class="MyApp.MainWindow"
        Title="MyApp">
    <Grid Background="{DynamicResource ResourceKey=PrimaryBackground}" ColumnDefinitions="Auto, *">
        <Border Grid.Column="0" Padding="20" Background="{DynamicResource ResourceKey=PrimaryBackgroundGradient}">
            <Grid RowDefinitions="*, Auto">
                <StackPanel Grid.Row="0" Spacing="12">
                    <Image Source="{SvgImage /Assets/Images/Sarif_Industries_Logo.svg}" Height="120"></Image>
                    <Button Content="Home" HorizontalAlignment="Stretch"></Button>
                    <Button Content="Home" HorizontalAlignment="Stretch"></Button>
                    <Button Content="Home" HorizontalAlignment="Stretch"></Button>
                    <Button Content="Home" HorizontalAlignment="Stretch"></Button>
                    <Button Content="Home" HorizontalAlignment="Stretch"></Button>
                </StackPanel>
                <Button Grid.Row="1" Foreground="White" Content="Settings" HorizontalAlignment="Stretch"></Button>
                
            </Grid>
        </Border>
    </Grid>
</Window>
